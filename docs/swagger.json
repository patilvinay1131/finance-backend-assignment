  "components": {
    "schemas": {
      "CategoryBreakdown": {
        "properties": {
          "category": {
            "type": "string",
            "title": "Category"
          },
          "total_income": {
            "type": "number",
            "title": "Total Income"
          },
          "total_expense": {
            "type": "number",
            "title": "Total Expense"
          },
          "net": {
            "type": "number",
            "title": "Net"
          }
        },
        "type": "object",
        "required": [
          "category",
          "total_income",
          "total_expense",
          "net"
        ],
        "title": "CategoryBreakdown",
        "description": "Income/expense totals for a single category."
      },
      "CategorySummaryResponse": {
        "properties": {
          "categories": {
            "items": {
              "$ref": "#/components/schemas/CategoryBreakdown"
